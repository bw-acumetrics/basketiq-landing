---
const footerSections = [
  {
    title: 'Report',
    links: [
      { label: 'Overview', href: '/' },
      { label: 'All issues', href: '/reports' },
      { label: 'Methodology', href: '/#methodology' },
    ],
  },
  {
    title: 'Contact',
    links: [
      { label: 'hello@basketiq.co.bw', href: 'mailto:hello@basketiq.co.bw' },
      { label: 'Ask a custom question', href: 'mailto:hello@basketiq.co.bw?subject=Custom%20question' },
    ],
  },
];
---

<footer class="bg-primary text-white w-full py-16 px-8 mt-auto">
  <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-3 gap-12">
    <div class="col-span-2 md:col-span-1">
      <div class="flex items-center gap-2 mb-6">
        <span class="material-symbols-outlined text-primary-fixed text-2xl">local_drink</span>
        <div class="text-lg font-bold text-white font-headline leading-tight">
          BasketIQ<br /><span class="text-xs font-semibold text-primary-fixed uppercase tracking-widest">Consumer Goods Report · Beverages</span>
        </div>
      </div>
      <p class="text-slate-400 text-sm leading-relaxed">
        Category intelligence on Botswana beverages, built from real receipts collected through a WhatsApp consumer panel.
      </p>
    </div>
    {footerSections.map(section => (
      <div>
        <h4 class="font-bold text-primary-fixed mb-6 uppercase tracking-widest text-xs">{section.title}</h4>
        <ul class="space-y-4">
          {section.links.map(link => (
            <li>
              <a class="text-slate-400 hover:text-primary-fixed transition-colors text-sm" href={link.href}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-white/10 text-center">
    <p class="text-slate-500 text-sm tracking-wide">
      &copy; 2026 BasketIQ. All rights reserved.
    </p>
  </div>
</footer>
